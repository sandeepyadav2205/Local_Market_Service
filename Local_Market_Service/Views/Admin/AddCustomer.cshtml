@using Local_Market_Service.ViewModels
@model CustomerAddByAdminVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Customer";
}

<style>
    .page-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; }

    .back-link {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--text-muted); text-decoration: none; font-size: 14px; margin-bottom: 8px;
        transition: color 0.2s; font-weight: 500;
    }
    .back-link:hover { color: var(--accent); }
    
    .sec-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
        overflow: hidden; box-shadow: var(--shadow); display: flex; flex-direction: column;
    }
    .sec-card-head {
        padding: 20px 24px; border-bottom: 1px solid var(--border); background: var(--surface-2);
        display: flex; align-items: center; gap: 12px;
    }
    .sec-card-title { font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .sec-card-title i { color: var(--accent); font-size: 22px; }
    
    .cust-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding: 32px; }
    .full-width { grid-column: 1 / -1; }
    .cust-form-group { display: flex; flex-direction: column; gap: 8px; }
    .cust-form-group label { font-size: 13px; font-weight: 600; color: var(--text); }
    
    .cust-input-wrap { position: relative; display: flex; align-items: center; }
    .cust-input-wrap i { position: absolute; left: 16px; font-size: 18px; color: var(--text-muted); }
    .cust-form-input {
        width: 100%; padding: 12px 16px 12px 44px; border: 1px solid var(--border); border-radius: 12px;
        background: var(--bg); color: var(--text); font-size: 14px;
        transition: all 0.2s; font-family: inherit; font-weight: 500;
    }
    .cust-form-input:focus { outline: none; border-color: var(--accent); background: var(--surface); box-shadow: 0 0 0 4px rgba(30, 204, 96, 0.1); }
    .cust-form-input::placeholder { color: #a1a1aa; font-weight: 400; }
    
    .cust-file-input { padding-left: 44px; padding-top: 9px; padding-bottom: 9px; }
    
    .cust-form-footer {
        padding: 20px 32px; border-top: 1px solid var(--border);
        display: flex; justify-content: flex-end; gap: 12px; background: var(--surface-2);
    }
    .cust-action-btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 12px 24px; border-radius: 12px; font-weight: 700; font-size: 14px;
        border: 1px solid var(--border); color: var(--text); background: var(--surface);
        transition: all 0.2s; cursor: pointer; text-decoration: none;
    }
    .cust-action-btn:hover { background: var(--border); }
    
    .cust-btn-primary { background: var(--accent); color: white; border-color: var(--accent); }
    .cust-btn-primary:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(30,204,96,0.2); }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@media (max-width: 768px) { .cust-form-grid { grid-template-columns: 1fr; } }
</style>

<div class="page-wrap">
    <!-- Header -->
    <div>
        <a href="/Admin/Customers" class="back-link"><i class="ti ti-arrow-left"></i> Back to Customers</a>
        <div class="section-header" style="margin-bottom:0;">
            <div>
                <h1 style="font-family:'Outfit',sans-serif; font-size:26px; font-weight:800; color:var(--text); margin-bottom:4px;">Add Customer</h1>
                <p style="color:var(--text-muted); font-size:14px;">Create a new customer account manually.</p>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="sec-card">
        <div class="sec-card-head">
            <h2 class="sec-card-title"><i class="ti ti-user-plus"></i> Customer Details</h2>
        </div>

        <form action="/Admin/AddCustomer" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" style="color: #dc2626; padding: 20px 32px 0; font-weight:600;"></div>

            <div class="cust-form-grid">
                <!-- FullName -->
                <div class="cust-form-group full-width">
                    <label for="FullName">Full Name <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-user" style="color: var(--blue);"></i>
                        <input type="text" id="FullName" asp-for="FullName" class="cust-form-input" placeholder="e.g. Rahul Sharma" required />
                    </div>
                    <span asp-validation-for="FullName" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- Email -->
                <div class="cust-form-group">
                    <label for="Email">Email Address</label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-mail" style="color: var(--red);"></i>
                        <input type="email" id="Email" asp-for="Email" class="cust-form-input" placeholder="e.g. rahul.sharma@gmail.com" />
                    </div>
                    <span asp-validation-for="Email" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- MobileNumber -->
                <div class="cust-form-group">
                    <label for="MobileNumber">Phone <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-phone" style="color: var(--green);"></i>
                        <input type="tel" id="MobileNumber" asp-for="MobileNumber" class="cust-form-input" placeholder="e.g. +91 98765 43210" required />
                    </div>
                    <span asp-validation-for="MobileNumber" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- Address -->
                <div class="cust-form-group full-width">
                    <label for="Address">Full Address <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-map-pin" style="color: var(--purple);"></i>
                        <input type="text" id="Address" asp-for="Address" class="cust-form-input" placeholder="e.g. Block C, Indira Nagar" required />
                    </div>
                    <span asp-validation-for="Address" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- City -->
                <div class="cust-form-group">
                    <label for="City">City <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-building" style="color: var(--amber);"></i>
                        <input type="text" id="City" asp-for="City" class="cust-form-input" placeholder="e.g. Lucknow" required />
                    </div>
                    <span asp-validation-for="City" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- State -->
                <div class="cust-form-group">
                    <label for="State">State <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-map" style="color: var(--blue);"></i>
                        <input type="text" id="State" asp-for="State" class="cust-form-input" placeholder="e.g. Uttar Pradesh" required />
                    </div>
                    <span asp-validation-for="State" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- Pincode -->
                <div class="cust-form-group">
                    <label for="Pincode">Pin Code <span style="color:#dc2626;">*</span></label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-hash" style="color: var(--text-muted);"></i>
                        <input type="text" id="Pincode" asp-for="Pincode" class="cust-form-input" placeholder="e.g. 226016" required />
                    </div>
                    <span asp-validation-for="Pincode" style="color: #dc2626; font-size: 12px;"></span>
                </div>

                <!-- Image -->
                <div class="cust-form-group">
                    <label for="Image">Profile Image</label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-camera" style="color: var(--accent);"></i>
                        <input type="file" id="Image" asp-for="Image" accept="image/*" class="cust-form-input cust-file-input" />
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="cust-form-footer">
                <a href="/Admin/Customers" class="cust-action-btn">Cancel</a>
                <button type="submit" class="cust-action-btn cust-btn-primary">
                    <i class="ti ti-device-floppy" style="margin-right: 6px; font-size:18px;"></i> Save Customer
                </button>
            </div>
        </form>
    </div>
</div>
