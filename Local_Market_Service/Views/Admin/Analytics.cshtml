@{
    ViewData["Title"] = "Analytics";
    Layout = "_AdminLayout";
}

<!-- Chart.js for high-fidelity data visualization -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    /* Analytics Specific Styles */
    .dashboard-header {
        margin-bottom: 24px;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
        animation: fadeInUp 0.4s ease both;
    }
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: var(--shadow);
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
        border-color: var(--accent);
    }
    .stat-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }
    .stat-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .stat-value {
        font-family: 'Outfit', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.5px;
    }
    .stat-label {
        font-size: 14px;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* Layout Grids */
    .grid-2 {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
        animation: fadeInUp 0.5s ease both;
    }
    .grid-3 {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 24px;
        margin-bottom: 24px;
        animation: fadeInUp 0.6s ease both;
    }
    
    /* Card Styles */
    .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
    }
    .card-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--surface-2);
    }
    .card-title {
        font-family: 'Outfit', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .card-title i {
        color: var(--accent);
        font-size: 20px;
    }
    .card-meta {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
    }
    .card-action {
        font-size: 13px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }
    .card-action:hover {
        opacity: 0.8;
    }
    .card-body {
        padding: 24px;
    }

    /* Chart Containers */
    .ana-chart-container {
        position: relative;
        height: 300px;
        width: 100%;
    }
    .ana-doughnut-container {
        position: relative;
        height: 250px;
        width: 100%;
        margin: 0 auto;
    }

    /* Table Styles */
    .table-wrap {
        overflow-x: auto;
    }
    table {
        width: 100%;
        border-collapse: collapse;
    }
    th {
        text-align: left;
        padding: 12px 24px;
        font-size: 12px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
    }
    td {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
        color: var(--text);
    }
    tr:last-child td {
        border-bottom: none;
    }
    tr:hover {
        background: var(--surface-2);
    }
    
    .pill {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }
    
    .ana-td-provider {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .td-avatar {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: var(--accent-bg);
        color: var(--accent-txt);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
    }
    .td-name {
        font-weight: 600;
        color: var(--text);
    }
    .ana-td-category {
        font-size: 12px;
        color: var(--text-muted);
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@media (max-width: 1024px) {
        .grid-2, .grid-3 { grid-template-columns: 1fr; }
    }
</style>

<div class="section-header" style="margin-bottom: 24px;">
    <div>
        <h1 style="font-family: 'Outfit'; font-size: 26px; font-weight: 800; color: var(--text); margin-bottom: 4px;">Analytics Overview</h1>
        <div style="color: var(--text-muted); font-size: 14px;">Deep dive into marketplace metrics and platform performance.</div>
    </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon" style="background:var(--green-bg); color:var(--green)">
                <i class="ti ti-wallet"></i>
            </div>
        </div>
        <div class="stat-info">
            <div class="stat-value">₹@ViewBag.TotalRevenue.ToString("N0")</div>
            <div class="stat-label">Total Revenue (Completed)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon" style="background:var(--blue-bg); color:var(--blue)">
                <i class="ti ti-calendar-check"></i>
            </div>
        </div>
        <div class="stat-info">
            <div class="stat-value">@ViewBag.TotalBookings</div>
            <div class="stat-label">Total Bookings (All-Time)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon" style="background:var(--amber-bg); color:var(--amber)">
                <i class="ti ti-receipt"></i>
            </div>
        </div>
        <div class="stat-info">
            <div class="stat-value">₹@ViewBag.AvgBookingValue.ToString("N0")</div>
            <div class="stat-label">Avg Booking Value (ABV)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon" style="background:var(--purple-bg); color:var(--purple)">
                <i class="ti ti-users"></i>
            </div>
        </div>
        <div class="stat-info">
            <div class="stat-value">@ViewBag.TotalUsers</div>
            <div class="stat-label">Total Registered Users</div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="grid-2">
    <!-- Line Chart: Revenue & Bookings -->
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title"><i class="ti ti-chart-line"></i>Platform Growth (6 Months)</div>
                <div class="card-meta">Revenue & User acquisition trends</div>
            </div>
        </div>
        <div class="card-body">
            <div class="ana-chart-container">
                <canvas id="ana-revenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Doughnut Chart: Booking Status -->
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title"><i class="ti ti-chart-pie-2"></i>Booking Distribution</div>
                <div class="card-meta">By current status</div>
            </div>
        </div>
        <div class="card-body">
            <div class="ana-doughnut-container">
                <canvas id="ana-statusChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Service categories and top performance table -->
<div class="grid-3">
    <!-- Horizontal Bar: Category Volume -->
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title"><i class="ti ti-tag"></i>Category Performance</div>
                <div class="card-meta">Bookings per category</div>
            </div>
        </div>
        <div class="card-body">
            <div class="ana-chart-container" style="height: 310px;">
                <canvas id="ana-categoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Top Providers Table -->
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title"><i class="ti ti-medal"></i>Top Performing Providers</div>
                <div class="card-meta">Based on completed jobs & revenue</div>
            </div>
            <a href="/Admin/Providers" class="card-action">View All Providers</a>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th>Completed Jobs</th>
                        <th>Revenue Generated</th>
                        <th>Rating</th>
                    </tr>
                </thead>
                <tbody id="ana-top-providers-tbody">
                    <!-- Handled by script using DB data -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    /* -- Real Data from Backend ------------------------- */
    const monthlyLabels = @Html.Raw(ViewBag.MonthlyRevLabelsJson ?? "[]");
    const monthlyRevData = @Html.Raw(ViewBag.MonthlyRevValuesJson ?? "[]");
    const customerGrowthData = @Html.Raw(ViewBag.CustomerGrowthJson ?? "[]");
    const providerGrowthData = @Html.Raw(ViewBag.ProviderGrowthJson ?? "[]");
    
    const catLabels = @Html.Raw(ViewBag.CatPopLabelsJson ?? "[]");
    const catData = @Html.Raw(ViewBag.CatPopValuesJson ?? "[]");
    
    const statusLabels = @Html.Raw(ViewBag.StatusLabelsJson ?? "[]");
    const statusData = @Html.Raw(ViewBag.StatusValuesJson ?? "[]");
    
    const topProviders = @Html.Raw(ViewBag.TopProvidersJson ?? "[]");

    /* -- Render Top Providers Table ----------------------- */
    function renderTopProviders() {
        const tbody = document.getElementById('ana-top-providers-tbody');
        if(!topProviders || topProviders.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:30px;">No provider data available.</td></tr>';
            return;
        }

        tbody.innerHTML = topProviders.map((p, i) => {
            return `<tr style="animation: fadeInUp .4s ease ${0.1 + i * 0.05}s both">
                <td>
                    <div class="ana-td-provider">
                        <div class="td-avatar">${(p.Name || 'U').substring(0, 1).toUpperCase()}</div>
                        <div>
                            <div class="td-name">${p.Name}</div>
                            <div class="ana-td-category">${p.Business || 'Independent'}</div>
                        </div>
                    </div>
                </td>
                <td style="font-weight:600">${p.Jobs}</td>
                <td style="color:var(--green); font-weight:700;">₹${p.Revenue.toFixed(2)}</td>
                <td style="color:var(--amber); font-weight:600"><i class="ti ti-star-filled" style="font-size:12px;"></i> ${p.Rating || 'New'}</td>
            </tr>`;
        }).join('');
    }

    /* -- Chart.js Configurations -------------------------- */
    function initCharts() {
        // Assume CSS custom variables are available globally
        const colors = {
            gridColor: 'rgba(150, 150, 150, 0.1)',
            textColor: '#6b7280',
            tooltipBg: '#ffffff',
            tooltipBorder: '#e5e7eb',
            tooltipText: '#111827'
        };

        // 1. Revenue & Users Line Chart
        const ctxRev = document.getElementById('ana-revenueChart').getContext('2d');
        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: monthlyLabels,
                datasets: [
                    {
                        label: 'Revenue (₹)',
                        data: monthlyRevData,
                        borderColor: '#1ecc60',
                        backgroundColor: 'rgba(30, 204, 96, 0.08)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        yAxisID: 'yRevenue'
                    },
                    {
                        label: 'New Customers',
                        data: customerGrowthData,
                        borderColor: '#2563eb',
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        tension: 0.3,
                        yAxisID: 'yUsers'
                    },
                    {
                        label: 'New Providers',
                        data: providerGrowthData,
                        borderColor: '#f59e0b',
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        borderDash: [3, 3],
                        tension: 0.3,
                        yAxisID: 'yUsers'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { labels: { color: colors.textColor, font: { family: 'inherit', size: 12 } } },
                    tooltip: {
                        backgroundColor: colors.tooltipBg,
                        borderColor: colors.tooltipBorder,
                        borderWidth: 1,
                        titleColor: colors.tooltipText,
                        bodyColor: colors.tooltipText,
                        padding: 10
                    }
                },
                scales: {
                    x: {
                        grid: { color: colors.gridColor },
                        ticks: { color: colors.textColor, font: { family: 'inherit' } }
                    },
                    yRevenue: {
                        type: 'linear',
                        position: 'left',
                        grid: { color: colors.gridColor },
                        ticks: { color: colors.textColor, font: { family: 'inherit' }, callback: value => '₹' + value }
                    },
                    yUsers: {
                        type: 'linear',
                        position: 'right',
                        grid: { drawOnChartArea: false },
                        ticks: { color: colors.textColor, font: { family: 'inherit' }, stepSize: 1 }
                    }
                }
            }
        });

        // 2. Booking Status Doughnut Chart
        const ctxStatus = document.getElementById('ana-statusChart').getContext('2d');
        const statusColorsMap = {
            'Completed': '#1ecc60',
            'Accepted': '#3b82f6',
            'Pending': '#f59e0b',
            'Rejected': '#ef4444',
            'Cancelled': '#6b7280'
        };
        const bgColors = statusLabels.map(s => statusColorsMap[s] || '#9ca3af');

        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: bgColors,
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { color: colors.textColor, font: { family: 'inherit' } } },
                    tooltip: {
                        backgroundColor: colors.tooltipBg,
                        borderColor: colors.tooltipBorder,
                        borderWidth: 1,
                        titleColor: colors.tooltipText,
                        bodyColor: colors.tooltipText
                    }
                },
                cutout: '65%'
            }
        });

        // 3. Category Performance Horizontal Bar Chart
        const ctxCat = document.getElementById('ana-categoryChart').getContext('2d');
        const catColors = ['#1ecc60', '#3b82f6', '#f59e0b', '#8b5cf6', '#ec4899', '#14b8a6', '#f43f5e'];
        
        new Chart(ctxCat, {
            type: 'bar',
            data: {
                labels: catLabels,
                datasets: [{
                    label: 'Total Bookings',
                    data: catData,
                    backgroundColor: catLabels.map((_, i) => catColors[i % catColors.length]),
                    borderRadius: 6
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: colors.tooltipBg,
                        borderColor: colors.tooltipBorder,
                        borderWidth: 1,
                        titleColor: colors.tooltipText,
                        bodyColor: colors.tooltipText
                    }
                },
                scales: {
                    x: {
                        grid: { color: colors.gridColor },
                        ticks: { color: colors.textColor, font: { family: 'inherit' }, stepSize: 1 }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { color: colors.textColor, font: { family: 'inherit' } }
                    }
                }
            }
        });
    }

    /* -- Init --------------------------------------------- */
    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("page-title").innerText = "Analytics";
        document.getElementById("page-crumb").innerText = "Analytics";
        renderTopProviders();
        initCharts();
    });
</script>
