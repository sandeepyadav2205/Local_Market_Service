@{
    ViewData["Title"] = "Bookings";
    Layout = "_AdminLayout";
}

@model ICollection<Local_Market_Service.Models.Booking>

<style>
    .page-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; }

    /* ── Stats Grid ──────────────────────────────────────── */
    .admin-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .admin-stat {
        background: var(--surface); border: 1px solid var(--border); border-radius: 18px;
        padding: 22px 20px; box-shadow: var(--shadow); transition: transform .2s, box-shadow .2s;
        position: relative; overflow: hidden;
    }
    .admin-stat:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .admin-stat::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 18px 18px 0 0; }
    
    .ast-blue::after { background: var(--blue); }
    .ast-green::after { background: var(--green); }
    .ast-amber::after { background: var(--amber); }
    .ast-red::after { background: var(--red); }

    .stat-icon-wrap { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 14px; }
    .ast-blue .stat-icon-wrap { background: var(--blue-bg); color: var(--blue-txt); }
    .ast-green .stat-icon-wrap { background: var(--green-bg); color: var(--green-txt); }
    .ast-amber .stat-icon-wrap { background: var(--amber-bg); color: var(--amber-txt); }
    .ast-red .stat-icon-wrap { background: var(--red-bg); color: var(--red-txt); }

    .stat-val { font-family: 'Outfit', sans-serif; font-size: 30px; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 6px; }
    .stat-lbl { font-size: 13px; color: var(--text-muted); font-weight: 600; display:flex; justify-content:space-between; }

    /* ── Table Card ──────────────────────────────────────── */
    .sec-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
    .sec-card-head { padding: 18px 24px; border-bottom: 1px solid var(--border); background: var(--surface-2); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .sec-card-title { font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .sec-card-title i { color: var(--accent); font-size: 20px; }

    .head-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    
    .search-box { position: relative; display: flex; align-items: center; }
    .search-box i { position: absolute; left: 14px; color: var(--text-muted); font-size: 16px; pointer-events: none; }
    .search-box input { padding: 10px 14px 10px 40px; border-radius: 12px; border: 1px solid var(--border); background: var(--surface); color: var(--text); font-family: inherit; font-size: 14px; width: 260px; transition: border-color .2s; }
    .search-box input:focus { outline: none; border-color: var(--accent); }

    .dash-table { width: 100%; border-collapse: collapse; }
    .dash-table th { padding: 14px 24px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); background: var(--bg); border-bottom: 1px solid var(--border); text-align: left; }
    .dash-table td { padding: 16px 24px; font-size: 14px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    .dash-table tr:last-child td { border-bottom: none; }
    .dash-table tbody tr:hover { background: var(--surface-2); }

    .user-block { display: flex; flex-direction: column; }
    .user-block-title { font-weight: 600; color: var(--text); }
    .user-block-sub { font-size: 12px; color: var(--text-muted); display:flex; align-items:center; gap:4px; margin-top:2px; }

    .s-badge { font-size: 11.5px; font-weight: 700; padding: 4px 12px; border-radius: 20px; display: inline-block; text-transform: capitalize; }
    .sb-completed { background: #d1fae5; color: #065f46; }
    .sb-pending { background: #fef3c7; color: #92400e; }
    .sb-cancelled { background: #fee2e2; color: #991b1b; }
    .sb-confirmed { background: #eff6ff; color: #1e3a8a; }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@media(max-width: 1024px) { .admin-stats { grid-template-columns: 1fr 1fr; } }
    @@media(max-width: 768px) { .admin-stats { grid-template-columns: 1fr; } .search-box input { width: 100%; } }
</style>

<div class="page-wrap">
    <!-- Header -->
    <div class="section-header" style="margin-bottom:0;">
        <div>
            <h1 style="font-family:'Outfit',sans-serif; font-size:26px; font-weight:800; color:var(--text); margin-bottom:4px;">Platform Bookings</h1>
            <p style="color:var(--text-muted); font-size:14px;">Monitor and manage all service bookings across the platform.</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="admin-stats">
        <div class="admin-stat ast-blue">
            <div class="stat-icon-wrap"><i class="ti ti-calendar-event"></i></div>
            <div class="stat-val">@Model.Count</div>
            <div class="stat-lbl">Total Bookings</div>
        </div>
        <div class="admin-stat ast-green">
            <div class="stat-icon-wrap"><i class="ti ti-check"></i></div>
            <div class="stat-val">@Model.Count(b => b.Status?.ToLower() == "completed")</div>
            <div class="stat-lbl">Completed Jobs</div>
        </div>
        <div class="admin-stat ast-amber">
            <div class="stat-icon-wrap"><i class="ti ti-clock"></i></div>
            <div class="stat-val">@Model.Count(b => b.Status?.ToLower() == "pending")</div>
            <div class="stat-lbl">Pending</div>
        </div>
        <div class="admin-stat ast-red">
            <div class="stat-icon-wrap"><i class="ti ti-x"></i></div>
            <div class="stat-val">@Model.Count(b => b.Status?.ToLower() == "cancelled" || b.Status?.ToLower() == "rejected")</div>
            <div class="stat-lbl">Cancelled</div>
        </div>
    </div>

    <!-- Table -->
    <div class="sec-card">
        <div class="sec-card-head">
            <div class="sec-card-title"><i class="ti ti-list"></i> Booking Log</div>
            <div class="head-actions">
                <div class="search-box">
                    <i class="ti ti-search"></i>
                    <input type="text" id="bkg-search" onkeyup="filterTable()" placeholder="Search bookings..." />
                </div>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Booking ID</th>
                        <th>Customer</th>
                        <th>Provider</th>
                        <th>Service</th>
                        <th>Date & Time</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="bkg-tbody">
                    @foreach(var b in Model.OrderByDescending(x => x.ServiceDate))
                    {
                        <tr>
                            <td style="font-family: monospace; font-weight: 700; color: var(--text-muted); font-size: 15px;">#@b.Id</td>
                            <td>
                                <div class="user-block">
                                    <div class="user-block-title">
                                        <a href="/Admin/ViewCustomer/@b.CustomerId" style="text-decoration:none; color:var(--text); transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">@(b.Customer?.ApplicationUser?.FullName ?? "Unknown")</a>
                                    </div>
                                    <div class="user-block-sub"><i class="ti ti-phone"></i> @(b.Customer?.ApplicationUser?.PhoneNumber ?? "—")</div>
                                </div>
                            </td>
                            <td>
                                <div class="user-block">
                                    <div class="user-block-title">
                                        <a href="/Admin/ViewProvider/@b.ProviderId" style="text-decoration:none; color:var(--text); transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">@(b.Provider?.ApplicationUser?.FullName ?? "Unknown")</a>
                                    </div>
                                    <div class="user-block-sub"><i class="ti ti-phone"></i> @(b.Provider?.ApplicationUser?.PhoneNumber ?? "—")</div>
                                </div>
                            </td>
                            <td style="font-weight: 600; color: var(--text);">@(b.Service?.Name ?? "—")</td>
                            <td>
                                <div class="user-block-title">@b.ServiceDate.ToString("MMM dd, yyyy")</div>
                                <div class="user-block-sub"><i class="ti ti-clock"></i> @b.ServiceDate.ToString("hh:mm tt")</div>
                            </td>
                            <td style="font-weight: 700; color: var(--green-txt);">₹@(b.Amount?.ToString("0.00") ?? "0.00")</td>
                            <td>
                                @{
                                    string status = b.Status?.ToLower() ?? "pending";
                                    string badgeClass = status == "completed" ? "sb-completed" : 
                                                        (status == "cancelled" || status == "rejected" ? "sb-cancelled" : 
                                                        (status == "confirmed" || status == "accepted" ? "sb-confirmed" : "sb-pending"));
                                }
                                <span class="s-badge @badgeClass">@(b.Status ?? "Pending")</span>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr><td colspan="7" style="text-align:center; padding:40px; color:var(--text-muted);">No bookings found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("page-title").innerText = "Bookings";
        document.getElementById("page-crumb").innerText = "Bookings";
    });

    function filterTable() {
        const query = document.getElementById('bkg-search').value.toLowerCase();
        const rows = document.querySelectorAll('#bkg-tbody tr');
        rows.forEach(row => {
            if(row.children.length === 1) return;
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }
</script>
