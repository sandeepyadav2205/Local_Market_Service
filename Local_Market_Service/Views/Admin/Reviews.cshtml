@{
    ViewData["Title"] = "Reviews";
    Layout = "_AdminLayout";
}

@model ICollection<Local_Market_Service.Models.Review>

<style>
    .page-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; }

    /* ── Stats Grid ──────────────────────────────────────── */
    .admin-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .admin-stat {
        background: var(--surface); border: 1px solid var(--border); border-radius: 18px;
        padding: 22px 20px; box-shadow: var(--shadow); transition: transform .2s, box-shadow .2s;
        position: relative; overflow: hidden;
    }
    .admin-stat:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .admin-stat::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 18px 18px 0 0; }
    
    .ast-blue::after { background: var(--blue); }
    .ast-amber::after { background: var(--amber); }

    .stat-icon-wrap { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 14px; }
    .ast-blue .stat-icon-wrap { background: var(--blue-bg); color: var(--blue-txt); }
    .ast-amber .stat-icon-wrap { background: var(--amber-bg); color: var(--amber-txt); }

    .stat-val { font-family: 'Outfit', sans-serif; font-size: 30px; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 6px; }
    .stat-lbl { font-size: 13px; color: var(--text-muted); font-weight: 600; display:flex; justify-content:space-between; }

    /* ── Table Card ──────────────────────────────────────── */
    .sec-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
    .sec-card-head { padding: 18px 24px; border-bottom: 1px solid var(--border); background: var(--surface-2); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .sec-card-title { font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .sec-card-title i { color: var(--accent); font-size: 20px; }

    .head-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    
    .search-box { position: relative; display: flex; align-items: center; }
    .search-box i { position: absolute; left: 14px; color: var(--text-muted); font-size: 16px; pointer-events: none; }
    .search-box input { padding: 10px 14px 10px 40px; border-radius: 12px; border: 1px solid var(--border); background: var(--surface); color: var(--text); font-family: inherit; font-size: 14px; width: 260px; transition: border-color .2s; }
    .search-box input:focus { outline: none; border-color: var(--accent); }

    .dash-table { width: 100%; border-collapse: collapse; }
    .dash-table th { padding: 14px 24px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); background: var(--bg); border-bottom: 1px solid var(--border); text-align: left; }
    .dash-table td { padding: 16px 24px; font-size: 14px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    .dash-table tr:last-child td { border-bottom: none; }
    .dash-table tbody tr:hover { background: var(--surface-2); }

    .rating-stars { display: flex; gap: 2px; color: var(--amber); font-size: 14px; }
    .rating-stars i.empty { color: var(--border); }

    .user-block { display: flex; align-items: center; gap: 10px; }
    .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: var(--text-sec); border: 1px solid var(--border); overflow: hidden; }
    .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
    
    .comment-box { max-width: 300px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; font-size: 13px; color: var(--text-muted); line-height: 1.4; }
    
    .action-btns { display: flex; gap: 8px; align-items: center; }
    .act-btn { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; text-decoration: none; font-size: 16px; transition: all .2s; border: 1px solid transparent; cursor: pointer; }
    .ab-del { background: var(--red-bg); color: var(--red); border-color: rgba(220,38,38,.2); }
    .ab-del:hover { background: var(--red); color: #fff; }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @@media(max-width: 768px) { .admin-stats { grid-template-columns: 1fr; } .search-box input { width: 100%; } }
</style>

<div class="page-wrap">
    <!-- Header -->
    <div class="section-header" style="margin-bottom:0;">
        <div>
            <h1 style="font-family:'Outfit',sans-serif; font-size:26px; font-weight:800; color:var(--text); margin-bottom:4px;">Platform Reviews</h1>
            <p style="color:var(--text-muted); font-size:14px;">Monitor and manage customer feedback across the platform.</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="admin-stats">
        <div class="admin-stat ast-blue">
            <div class="stat-icon-wrap"><i class="ti ti-message-star"></i></div>
            <div class="stat-val">@Model.Count</div>
            <div class="stat-lbl">Total Reviews</div>
        </div>
        
        @{
            double avgRating = Model.Any() ? Model.Average(r => {
                if (double.TryParse(r.Rating, out double val)) return val;
                return 0.0;
            }) : 0.0;
        }
        <div class="admin-stat ast-amber">
            <div class="stat-icon-wrap"><i class="ti ti-star"></i></div>
            <div class="stat-val">@(avgRating.ToString("0.1")) <span style="font-size:18px; color:var(--text-muted);">/ 5.0</span></div>
            <div class="stat-lbl">Average Rating</div>
        </div>
    </div>

    <!-- Table -->
    <div class="sec-card">
        <div class="sec-card-head">
            <div class="sec-card-title"><i class="ti ti-messages"></i> Feedback Log</div>
            <div class="head-actions">
                <div class="search-box">
                    <i class="ti ti-search"></i>
                    <input type="text" id="rev-search" onkeyup="filterTable()" placeholder="Search feedback..." />
                </div>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Provider</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="rev-tbody">
                    @foreach(var r in Model.OrderByDescending(x => x.CreatedAt))
                    {
                        <tr>
                            <td style="font-size: 13px; color: var(--text-muted); white-space: nowrap;">
                                @r.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <div class="user-block">
                                    <div class="user-avatar">
                                        @if(!string.IsNullOrEmpty(r.Customer?.ApplicationUser?.profileImage)) {
                                            <img src="/Images/@r.Customer.ApplicationUser.profileImage" onerror="this.style.display='none'" />
                                        } else {
                                            <i class="ti ti-user"></i>
                                        }
                                    </div>
                                    <span style="font-weight: 500;">
                                        <a href="/Admin/ViewCustomer/@r.CustomerId" style="text-decoration:none; color:var(--text); transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">@(r.Customer?.ApplicationUser?.FullName ?? "Unknown")</a>
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div class="user-block">
                                    <div class="user-avatar">
                                        @if(!string.IsNullOrEmpty(r.Provider?.ApplicationUser?.profileImage)) {
                                            <img src="/Images/@r.Provider.ApplicationUser.profileImage" onerror="this.style.display='none'" />
                                        } else {
                                            <i class="ti ti-briefcase"></i>
                                        }
                                    </div>
                                    <span style="font-weight: 500;">
                                        <a href="/Admin/ViewProvider/@r.ProviderId" style="text-decoration:none; color:var(--text); transition:color .2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">@(r.Provider?.ApplicationUser?.FullName ?? "Unknown")</a>
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div class="rating-stars">
                                    @{
                                        int rating = 0;
                                        int.TryParse(r.Rating, out rating);
                                        for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= rating) { <i class="ti ti-star-filled"></i> }
                                            else { <i class="ti ti-star empty"></i> }
                                        }
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="comment-box" title="@r.Comment">
                                    @(string.IsNullOrEmpty(r.Comment) ? "—" : r.Comment)
                                </div>
                            </td>
                            <td>
                                <div class="action-btns" style="justify-content:flex-end;">
                                    <button class="act-btn ab-del" title="Delete Review" onclick="alert('Delete functionality to be implemented')">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr><td colspan="6" style="text-align:center; padding:40px; color:var(--text-muted);">No reviews found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("page-title").innerText = "Reviews";
        document.getElementById("page-crumb").innerText = "Reviews";
    });

    function filterTable() {
        const query = document.getElementById('rev-search').value.toLowerCase();
        const rows = document.querySelectorAll('#rev-tbody tr');
        rows.forEach(row => {
            if(row.children.length === 1) return;
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }
</script>
