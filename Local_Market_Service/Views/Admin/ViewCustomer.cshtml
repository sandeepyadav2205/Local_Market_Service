@model Local_Market_Service.Models.Customer
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Customer Details";
}

<style>
    .page-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 14px;
        margin-bottom: 16px;
        transition: color 0.2s;
    }
    .back-link:hover {
        color: var(--accent);
    }
    .profile-hero {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 24px;
        box-shadow: var(--shadow);
    }
    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--accent-bg);
        color: var(--accent-txt);
        font-size: 32px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .profile-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }
    .profile-info {
        flex: 1;
    }
    .profile-name {
        font-size: 24px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .status-pill {
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 600;
        background: var(--green-bg);
        color: var(--green-txt);
    }
    .status-pill.inactive {
        background: var(--red-bg);
        color: var(--red-txt);
    }
    .profile-meta {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--text-muted);
        font-size: 14px;
    }
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 24px;
    }
    .info-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .info-label {
        font-size: 12px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .info-value {
        font-size: 14px;
        color: var(--text);
        font-weight: 500;
    }
    .inner-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .inner-stat-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }
    .s-blue { background: #eff6ff; color: #2563eb; }
    .s-green { background: #c8f7dc; color: #15803d; }
    .s-amber { background: #fef3c7; color: #d97706; }
    
    .stat-val {
        font-size: 24px;
        font-weight: 700;
        color: var(--text);
    }
    .stat-name {
        font-size: 12px;
        color: var(--text-muted);
    }
    .job-id {
        font-family: monospace;
        color: var(--accent);
        font-weight: 600;
    }
    .job-status {
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: 600;
    }
    .js-completed { background: var(--green-bg); color: var(--green-txt); }
    .js-pending { background: var(--amber-bg); color: var(--amber-txt); }
    .js-cancelled { background: var(--red-bg); color: var(--red-txt); }

    .btn-edit {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 8px 16px;
        border-radius: 8px;
        color: var(--text);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s;
    }
    .btn-edit:hover {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="page-wrap">

    <!-- Header -->
    <div>
        <a href="/Admin/Customers" class="back-link"><i class="ti ti-arrow-left"></i> Back to Customers</a>
        <div class="section-header">
            <h1 class="section-title">Customer Details</h1>
            <div class="header-actions">
                <a asp-action="EditCustomer" asp-route-id="@Model.Id" class="btn-edit">
                    <i class="ti ti-edit"></i> Edit Customer
                </a>
            </div>
        </div>
    </div>

    <!-- Profile Hero -->
    <div class="profile-hero">
        <div class="profile-avatar">
            @if(!string.IsNullOrEmpty(Model.ApplicationUser?.profileImage)) {
                <img src="/Images/@Model.ApplicationUser.profileImage" alt="Profile" />
            } else {
                @(Model.ApplicationUser?.FullName != null && Model.ApplicationUser.FullName.Length >= 2 ? Model.ApplicationUser.FullName.Substring(0, 2).ToUpper() : "CU")
            }
        </div>
        <div class="profile-info">
            <div class="profile-name">
                @Model.ApplicationUser?.FullName
                @if (Model.ApplicationUser != null && Model.ApplicationUser.IsActive)
                {
                    <span class="status-pill">Active</span>
                }
                else
                {
                    <span class="status-pill inactive">Inactive</span>
                }
            </div>
            <div class="profile-meta">
                <div class="meta-item"><i class="ti ti-mail"></i> @Model.ApplicationUser?.Email</div>
                <div class="meta-item"><i class="ti ti-phone"></i> @Model.ApplicationUser?.PhoneNumber</div>
                <div class="meta-item"><i class="ti ti-map-pin"></i> @Model.City, @Model.State</div>
            </div>
        </div>
    </div>

    <!-- Details Grid -->
    <div class="details-grid">

        <!-- Left Column: Personal Info -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-user-circle"></i> Personal Information</h3>
            </div>
            <div class="card-body" style="padding: 20px;">
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">Full Name</span>
                        <span class="info-value">@Model.ApplicationUser?.FullName</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email Address</span>
                        <span class="info-value">@Model.ApplicationUser?.Email</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Phone Number</span>
                        <span class="info-value">@Model.ApplicationUser?.PhoneNumber</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Full Address</span>
                        <span class="info-value">@Model.Address, @Model.City, @Model.State @Model.Pincode</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Join Date</span>
                        <span class="info-value">@(Model.ApplicationUser?.CreatedAt.ToString("MMM dd, yyyy"))</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Activity & Stats -->
        <div>
            <!-- Stats row -->
            <div class="inner-stats">
                <div class="inner-stat-box">
                    <div class="stat-icon s-blue"><i class="ti ti-briefcase"></i></div>
                    <div class="stat-val">@(Model.Bookings?.Count ?? 0)</div>
                    <div class="stat-name">Jobs Booked</div>
                </div>
                <div class="inner-stat-box">
                    <div class="stat-icon s-green"><i class="ti ti-receipt-2"></i></div>
                    <div class="stat-val">₹ @(Model.Bookings?.Sum(b => b.Amount) ?? 0)</div>
                    <div class="stat-name">Total Spent</div>
                </div>
                <div class="inner-stat-box">
                    <div class="stat-icon s-amber"><i class="ti ti-star-filled"></i></div>
                    <div class="stat-val">N/A</div>
                    <div class="stat-name">Avg Rating Given</div>
                </div>
            </div>

            <!-- Recent Bookings Table -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="ti ti-history"></i> Recent Bookings</h3>
                </div>
                <div class="card-body">
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Job ID</th>
                                    <th>Service</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if(Model.Bookings != null && Model.Bookings.Any()) {
                                    foreach(var booking in Model.Bookings.OrderByDescending(b => b.BookingDate)) {
                                        <tr>
                                            <td><span class="job-id">#JB-@booking.Id</span></td>
                                            <td>@(booking.Service?.Name ?? "Unknown Service")</td>
                                            <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                                            <td>₹ @booking.Amount</td>
                                            <td>
                                                <span class="job-status @(booking.Status.ToLower() == "completed" ? "js-completed" : booking.Status.ToLower() == "cancelled" ? "js-cancelled" : "js-pending")">
                                                    @booking.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="5" style="text-align:center; padding:20px; color:var(--text-muted);">No recent bookings</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div> <!-- /Right Column -->
    </div>

</div><!-- /page-wrap -->
