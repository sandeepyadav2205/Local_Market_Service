@model IEnumerable<Local_Market_Service.Models.Cart>
@{
    ViewData["Title"] = "My Cart";
    Layout = "_CustomerLayout";
    decimal totalAmount = Model != null ? Model.Sum(c => (decimal)(c.Service?.Price ?? 0) * c.Quantity) : 0;
    int itemCount = Model?.Count() ?? 0;
}
<style>
    .cart-wrap {
        display: flex;
        flex-direction: column;
        gap: 28px;
        animation: fadeInUp .45s ease both;
    }

    /* ── Page Header ──────────────────────────────────────── */
    .cart-page-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }
    .cart-page-title {
        font-family: 'Outfit', sans-serif;
        font-size: 30px;
        font-weight: 800;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .cart-count-badge {
        background: var(--accent);
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .btn-continue {
        background: var(--bg);
        color: var(--text-sec);
        border: 1.5px solid var(--border);
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all .2s;
    }
    .btn-continue:hover { background: var(--accent-bg); color: var(--accent-txt); border-color: var(--accent); }

    /* ── Main Layout ──────────────────────────────────────── */
    .cart-main {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 28px;
        align-items: flex-start;
    }

    /* ── Cart Items ───────────────────────────────────────── */
    .cart-items { display: flex; flex-direction: column; gap: 16px; }

    .cart-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        gap: 20px;
        align-items: center;
        box-shadow: var(--shadow);
        transition: transform .2s, box-shadow .2s, border-color .2s;
        position: relative;
        overflow: hidden;
    }
    .cart-item::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
        background: var(--accent);
        border-radius: 4px 0 0 4px;
        opacity: 0;
        transition: opacity .2s;
    }
    .cart-item:hover { transform: translateX(4px); box-shadow: var(--shadow-lg); border-color: rgba(30,204,96,.3); }
    .cart-item:hover::before { opacity: 1; }
    .item-img {
        width: 110px; height: 110px;
        object-fit: cover;
        border-radius: 16px;
        flex-shrink: 0;
        box-shadow: var(--shadow);
    }
    .item-content { flex: 1; }
    .item-name {
        font-family: 'Outfit', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
    }
    .item-prov {
        font-size: 13px;
        color: var(--text-sec);
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 12px;
    }
    .item-prov i { color: var(--accent); }
    .item-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .qty-badge {
        background: var(--accent-bg);
        color: var(--accent-txt);
        font-size: 12px;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .unit-price {
        font-size: 13px;
        color: var(--text-muted);
    }

    .item-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 16px;
        flex-shrink: 0;
    }
    .item-total {
        font-family: 'Outfit', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: var(--text);
    }
    .btn-remove {
        background: var(--bg);
        color: var(--red-txt);
        border: 1.5px solid var(--red-bg);
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
    }
    .btn-remove:hover { background: var(--red-bg); transform: scale(1.02); }

    /* ── Order Summary Card ───────────────────────────────── */
    .summary-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        position: sticky;
        top: 24px;
    }
    .summary-header {
        background: linear-gradient(135deg, #0f7a38, #1ecc60);
        padding: 24px 28px;
        color: #fff;
    }
    .summary-header-title {
        font-family: 'Outfit', sans-serif;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 4px;
    }
    .summary-header-sub { font-size: 13px; opacity: .8; }
    .summary-body { padding: 28px; }
    .summary-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }
    .summary-line-lbl { font-size: 14px; color: var(--text-sec); }
    .summary-line-val { font-size: 14px; font-weight: 600; color: var(--text); }
    .summary-divider {
        border: none;
        border-top: 1.5px dashed var(--border);
        margin: 20px 0;
    }
    .summary-total-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }
    .summary-total-lbl {
        font-family: 'Outfit', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
    }
    .summary-total-val {
        font-family: 'Outfit', sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: var(--accent-txt);
    }
    .btn-checkout-main {
        display: block;
        width: 100%;
        background: linear-gradient(135deg, #0f7a38, #1ecc60);
        color: #fff;
        text-align: center;
        padding: 16px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 16px;
        text-decoration: none;
        transition: transform .2s, box-shadow .2s;
        box-shadow: 0 6px 20px rgba(30,204,96,.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    .btn-checkout-main:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(30,204,96,.4); }
    .secure-note {
        text-align: center;
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    /* ── Empty State ──────────────────────────────────────── */
    .empty-cart {
        text-align: center;
        padding: 100px 32px;
        background: var(--surface);
        border-radius: 20px;
        border: 2px dashed var(--border);
    }
    .empty-cart-icon {
        width: 100px; height: 100px;
        background: var(--accent-bg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }
    .empty-cart-icon i { font-size: 48px; color: var(--accent); }
    .empty-cart h2 {
        font-family: 'Outfit', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 10px;
    }
    .empty-cart p { font-size: 15px; color: var(--text-muted); margin-bottom: 32px; }
    .btn-browse {
        background: var(--accent);
        color: #fff;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: background .2s, transform .2s;
        box-shadow: 0 4px 16px rgba(30,204,96,.3);
    }
    .btn-browse:hover { background: var(--green-txt); transform: translateY(-2px); }

    @@media (max-width: 960px) {
        .cart-main { grid-template-columns: 1fr; }
        .summary-card { position: static; }
    }
    @@media (max-width: 580px) {
        .cart-item { flex-direction: column; }
        .item-img { width: 100%; height: 180px; }
        .item-right { align-items: flex-start; flex-direction: row; justify-content: space-between; width: 100%; }
    }
</style>

<div class="cart-wrap">

    <!-- ── Page Header ────────────────────────────────────── -->
    <div class="cart-page-head">
        <div class="cart-page-title">
            <i class="ti ti-shopping-cart" style="color: var(--accent);"></i>
            My Cart
            @if (itemCount > 0)
            {
                <span class="cart-count-badge">@itemCount</span>
            }
        </div>
        <a asp-action="Explore" class="btn-continue">
            <i class="ti ti-arrow-left"></i> Continue Shopping
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="cart-main">
            <!-- ── Items ───────────────────────────────────── -->
            <div class="cart-items">
                @foreach (var item in Model)
                {
                    decimal lineTotal = (decimal)(item.Service?.Price ?? 0) * item.Quantity;
                    <div class="cart-item">
                        <img src="/Images/@(item.Service?.ImageUrl ?? "default-svc.png")" class="item-img"
                             onerror="this.src='/Images/default-svc.png';" alt="@item.Service?.Name" />
                        <div class="item-content">
                            <div class="item-name">@item.Service?.Name</div>
                            <div class="item-prov">
                                <i class="ti ti-building-store"></i>
                                @(item.Service?.Provider?.BusinessName ?? "Independent Provider")
                            </div>
                            <div class="item-meta">
                                <span class="qty-badge"><i class="ti ti-stack-2"></i> Qty: @item.Quantity</span>
                                <span class="unit-price">₹@item.Service?.Price per visit</span>
                            </div>
                        </div>
                        <div class="item-right">
                            <div class="item-total">₹@lineTotal</div>
                            <a asp-action="RemoveFromCart" asp-route-id="@item.Id" class="btn-remove"
                               onclick="return confirm('Remove this service from cart?');">
                                <i class="ti ti-trash"></i> Remove
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- ── Summary ─────────────────────────────────── -->
            <div class="summary-card">
                <div class="summary-header">
                    <div class="summary-header-title">Order Summary</div>
                    <div class="summary-header-sub">@itemCount service@(itemCount != 1 ? "s" : "") in cart</div>
                </div>
                <div class="summary-body">
                    <div class="summary-line">
                        <span class="summary-line-lbl">Subtotal (@itemCount items)</span>
                        <span class="summary-line-val">₹@totalAmount</span>
                    </div>
                    <div class="summary-line">
                        <span class="summary-line-lbl">Platform Fee</span>
                        <span class="summary-line-val" style="color: var(--green-txt);">Free</span>
                    </div>
                    <div class="summary-line">
                        <span class="summary-line-lbl">Payment Mode</span>
                        <span class="summary-line-val">Pay After Service</span>
                    </div>
                    <hr class="summary-divider" />
                    <div class="summary-total-line">
                        <span class="summary-total-lbl">Total</span>
                        <span class="summary-total-val">₹@totalAmount</span>
                    </div>
                    <a asp-action="Checkout" class="btn-checkout-main">
                        <i class="ti ti-lock"></i> Proceed to Checkout
                    </a>
                    <div class="secure-note">
                        <i class="ti ti-shield-check"></i>
                        Secure & Safe Booking
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-cart">
            <div class="empty-cart-icon">
                <i class="ti ti-shopping-cart"></i>
            </div>
            <h2>Your Cart is Empty</h2>
            <p>Looks like you haven't added any services yet. Explore our offerings and book your first service!</p>
            <a asp-action="Explore" class="btn-browse">
                <i class="ti ti-search"></i> Browse Services
            </a>
        </div>
    }

</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("page-title").innerText = "Shopping Cart";
        document.getElementById("page-crumb").innerText = "Cart";
    });
</script>
