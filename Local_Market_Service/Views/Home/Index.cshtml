<!-- 🔹 Contact Us + Map Section -->
<section class="contact-section" id="contact">
    <!-- Decorative blobs -->
    <div class="ct-blob ct-blob-1"></div>
    <div class="ct-blob ct-blob-2"></div>
    <div class="container" style="position:relative;z-index:1;">

        <!-- Heading -->
        <div class="section-heading-wrapper text-center animate-fade-in delay-1">
            <span class="ct-section-badge"><i class="bi bi-chat-heart-fill me-2"></i>Contact Us</span>
            <h2 class="mt-3">Get In <span>Touch</span></h2>
            <p class="mx-auto" style="max-width:480px;">
                Have a question or need help? We'd love to hear from
                you.
                Our team responds within 24 hours.
            </p>
        </div>

        <div class="row g-4 align-items-stretch">

            <!-- LEFT: Info Cards + Form -->
            <div class="col-lg-5 d-flex flex-column gap-3">

                <!-- Contact Form -->
                <div class="ct-form-card animate-fade-in delay-2">
                    <div class="ct-form-title">
                        <div class="ct-form-title-icon"><i class="bi bi-send-fill"></i></div>
                        <div>
                            <h5 class="mb-0">Send a Message</h5>
                            <p class="mb-0">We'll get back to you soon</p>
                        </div>
                    </div>
                    <form>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="ct-input-group">
                                    <i class="bi bi-person"></i>
                                    <input type="text" class="ct-input" placeholder="Your Name">
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="ct-input-group">
                                    <i class="bi bi-envelope"></i>
                                    <input type="email" class="ct-input" placeholder="Email Address">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="ct-input-group">
                                    <i class="bi bi-chat-square-text"></i>
                                    <input type="text" class="ct-input" placeholder="Subject">
                                </div>
                            </div>
                            <div class="col-12">
                                <textarea class="ct-input ct-textarea" placeholder="Your message..."></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="ct-submit-btn">
                                    <i class="bi bi-send-fill"></i> Send Message
                                    <span class="ct-btn-shine"></span>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Quick Contact Info Row -->
                <div class="row g-2 mt-1 px-1">
                    <div class="col-4">
                        <div class="d-flex align-items-center gap-2 p-2 bg-white border rounded-3 text-muted"
                             style="font-size:0.75rem; font-weight:500;">
                            <i class="bi bi-pin-map-fill text-success"></i>
                            <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                Maharajganj,
                                UP
                            </span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="d-flex align-items-center gap-2 p-2 bg-white border rounded-3 text-muted"
                             style="font-size:0.75rem; font-weight:500;">
