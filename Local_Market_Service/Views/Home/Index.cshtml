@{
    ViewData["Title"] = "Trusted Local Services";
}

<!-- 🔹 Hero Section -->
<section class="hero-section-custom">
    <!-- Background decorations -->
    <div class="hero-bg-circle hero-bg-circle-1"></div>
    <div class="hero-bg-circle hero-bg-circle-2"></div>
    <div class="container">
        <div class="row align-items-center g-5">
            <!-- Left Text -->
            <div class="col-lg-6">
                <div class="hero-tag animate-fade-in delay-1">
                    <span class="hero-tag-dot"></span>
                    <i class="bi bi-patch-check-fill"></i> Trusted by 10,000+ Happy Customers
                </div>
                <h1 class="hero-title mt-3">
                    Your City's Best<br>
                    <span class="gradient-text">Services, One Tap</span><br>
                    Away
                </h1>
                <p class="hero-subtitle">
                    Book verified plumbers, electricians, cleaners & more — right at your doorstep. Fast
                    booking, transparent pricing, zero hassle.
                </p>

                <!-- Search box -->
                <div class="hero-search-wrapper">
                    <div class="hero-search-box">
                        <i class="bi bi-search"></i>
                        <input type="search" placeholder="e.g. Plumbing, Car Wash, Electrician...">
                        <button type="submit"><i class="bi bi-search me-1"></i> Search</button>
                    </div>
                </div>

                <!-- CTA Buttons -->
                <div class="hero-cta-row">
                    <a href="#services" class="hero-btn-primary">
                        <i class="bi bi-grid-fill"></i> Explore Services
                    </a>
                    <div class="dropdown d-inline-block">
                        <a href="#" class="hero-btn-secondary dropdown-toggle" data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-person-plus-fill"></i> Join Free
                        </a>
                        <ul class="dropdown-menu dropdown-menu-custom">
                            <li>
                                <a class="dropdown-item dropdown-item-custom" href="/Account/RegisterCustomer">
                                    <i class="bi bi-person-fill text-success"></i> Customer Registration
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item dropdown-item-custom" href="/Account/RegisterProvider">
                                    <i class="bi bi-briefcase-fill text-primary"></i> Provider Registration
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Stats -->
                <div class="hero-stats">
                    <div class="hero-stat">
                        <span>500+</span>
                        <p>Services</p>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat">
                        <span>200+</span>
                        <p>Providers</p>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat">
                        <span>4.9★</span>
                        <p>Avg Rating</p>
                    </div>
                    <div class="hero-stat-divider"></div>
                    <div class="hero-stat">
                        <span>10K+</span>
                        <p>Happy Users</p>
                    </div>
                </div>
            </div>
            <!-- Right Image -->
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-img-wrapper">
                    <img src="https://images.unsplash.com/photo-1628177142898-93e36e4e3a50?auto=format&fit=crop&w=1200&q=80"
                         alt="Trusted Local Services" class="hero-img">
                    <!-- Floating card 1 — bottom left -->
                    <div class="hero-img-card card-1">
                        <div class="hero-img-card-icon" style="background:#fef9c3; color:#d97706;">
                            <i class="bi bi-star-fill"></i>
                        </div>
                        <div>
                            <strong>4.9 / 5 Rating</strong>
                            <p>From 2,400+ reviews</p>
                        </div>
                    </div>
                    <!-- Floating card 2 — top right -->
                    <div class="hero-img-card card-2">
                        <div class="hero-img-card-icon" style="background:#dcfce7; color:#16a34a;">
                            <i class="bi bi-shield-check-fill"></i>
                        </div>
                        <div>
                            <strong>Verified Pros</strong>
                            <p>200+ trusted providers</p>
                        </div>
                    </div>
                    <!-- Floating card 3 — middle right -->
                    <div class="hero-img-card card-3">
                        <div class="hero-img-card-icon" style="background:#ede9fe; color:#7c3aed;">
                            <i class="bi bi-lightning-charge-fill"></i>
                        </div>
                        <div>
                            <strong>Quick Booking</strong>
                            <p>In under 2 minutes</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

