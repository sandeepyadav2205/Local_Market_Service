@model Local_Market_Service.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Change Password";
    Layout = "_ProviderLayout";
}

<style>
    .page-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; max-width: 900px; margin: 40px auto; width: 100%; padding: 0 20px; }
    
    .sec-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); }
    .sec-card-head { padding: 20px 24px; border-bottom: 1px solid var(--border); background: var(--surface-2); display: flex; align-items: center; gap: 12px; }
    .sec-card-title { font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .sec-card-title i { color: var(--accent); font-size: 22px; }
    
    .cust-form-grid { display: grid; grid-template-columns: 1fr; gap: 24px; padding: 32px; }
    .cust-form-group { display: flex; flex-direction: column; gap: 8px; }
    .cust-form-group label { font-size: 13px; font-weight: 600; color: var(--text); }
    
    .cust-input-wrap { position: relative; display: flex; align-items: center; }
    .cust-input-wrap i { position: absolute; left: 16px; font-size: 18px; color: var(--text-muted); }
    .cust-form-input {
        width: 100%; padding: 12px 16px 12px 44px; border: 1px solid var(--border); border-radius: 12px;
        background: var(--bg); color: var(--text); font-size: 14px; transition: all 0.2s; font-family: inherit; font-weight: 500;
    }
    .cust-form-input:focus { outline: none; border-color: var(--accent); background: var(--surface); box-shadow: 0 0 0 4px rgba(30, 204, 96, 0.1); }
    
    .cust-form-footer { padding: 20px 32px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; background: var(--surface-2); }
    .cust-btn-primary { background: var(--accent); color: white; border-color: var(--accent); padding: 12px 24px; border-radius: 12px; font-weight: 700; font-size: 14px; cursor: pointer; transition: all 0.2s; border: 1px solid transparent; display: inline-flex; align-items: center; gap: 8px; }
    .cust-btn-primary:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(30,204,96,0.2); }
    
    .alert-success { background: rgba(30, 204, 96, 0.1); border: 1px solid rgba(30, 204, 96, 0.2); color: var(--accent-txt); padding: 16px 20px; border-radius: 12px; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 12px; box-shadow: var(--shadow); }
    .alert-success i { font-size: 22px; }
    .text-danger { color: #dc2626; font-size: 13px; font-weight: 500; margin-top: 4px; display: block; }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="page-wrap">
    <!-- Header -->
    <div style="margin-bottom: 0;">
        <h1 style="font-family:'Outfit',sans-serif; font-size:28px; font-weight:800; color:var(--text); margin-bottom:4px;">Change Password</h1>
        <p style="color:var(--text-muted); font-size:14px;">Update your password regularly to keep your account secure.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">
            <i class="ti ti-circle-check"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Settings Form Area -->
    <div class="sec-card">
        <div class="sec-card-head">
            <div class="sec-card-title"><i class="ti ti-shield-lock"></i> Security Credentials</div>
        </div>
        
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="padding: 0 32px; padding-top: 24px; font-size: 15px;"></div>

            <div class="cust-form-grid">
                <div class="cust-form-group">
                    <label asp-for="CurrentPassword">Current Password</label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-key"></i>
                        <input asp-for="CurrentPassword" type="password" class="cust-form-input" placeholder="Enter your current password" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>
                
                <div class="cust-form-group">
                    <label asp-for="NewPassword">New Password</label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-lock"></i>
                        <input asp-for="NewPassword" type="password" class="cust-form-input" placeholder="Enter a strong new password" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
                
                <div class="cust-form-group">
                    <label asp-for="ConfirmPassword">Confirm New Password</label>
                    <div class="cust-input-wrap">
                        <i class="ti ti-shield-check"></i>
                        <input asp-for="ConfirmPassword" type="password" class="cust-form-input" placeholder="Confirm your new password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
            
            <div class="cust-form-footer">
                <button type="submit" class="cust-btn-primary">
                    <i class="ti ti-device-floppy"></i> Update Password
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
