@{
    ViewData["Title"] = "Customer Reviews";
    Layout = "_ProviderLayout";
}

<div class="section-header" style="margin-bottom: 24px;">
    <div>
        <h1 style="font-family: 'Outfit'; font-size: 24px; font-weight: 700; color: var(--text); margin-bottom: 4px;">Customer Reviews</h1>
        <p style="color: var(--text-muted); font-size: 13px;">See what customers are saying about your services.</p>
    </div>
</div>

<div class="card" style="text-align: center;">
    <div style="padding: 60px 40px; color: var(--text-sec);">
        <i class="ti ti-star" style="font-size: 64px; color: var(--border); margin-bottom: 16px; display: block;"></i>
        <h2 style="font-family: 'Outfit'; font-size: 20px; font-weight: 600; color: var(--text);">No Reviews Yet</h2>
        <p style="margin-top: 8px; font-size: 14px;">Once customers start booking your services and leaving reviews, they will appear here.</p>
    </div>
</div>
