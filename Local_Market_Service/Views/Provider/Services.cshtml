@model ICollection<Service>
@{
    ViewData["Title"] = "My Services";
    Layout = "_ProviderLayout";
    int total = Model?.Count ?? 0;
    int active = Model?.Count(s => s.Status?.ToLower() == "active") ?? 0;
}
<style>
    .svc-wrap { display: flex; flex-direction: column; gap: 24px; animation: fadeInUp .45s ease both; }

    /* ── Page Header ─────────────────────────────────────── */
    .page-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }
    .page-hdr-left h1 {
        font-family: 'Outfit', sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 4px;
    }
    .page-hdr-left p { font-size: 14px; color: var(--text-muted); }
    .btn-add-svc {
        background: linear-gradient(135deg, #0f7a38, #1ecc60);
        color: #fff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: transform .2s, box-shadow .2s;
        box-shadow: 0 4px 16px rgba(30,204,96,.3);
        white-space: nowrap;
    }
    .btn-add-svc:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(30,204,96,.38); }

    /* ── Stats Pills ─────────────────────────────────────── */
    .svc-stats { display: flex; gap: 12px; flex-wrap: wrap; }
    .svc-stat-pill {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: var(--shadow);
    }
    .svc-stat-icon { font-size: 22px; }
    .svc-stat-num { font-family: 'Outfit',sans-serif; font-size: 22px; font-weight: 800; color: var(--text); }
    .svc-stat-lbl { font-size: 12px; color: var(--text-muted); }

    /* ── Service Grid ────────────────────────────────────── */
    .svc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 20px;
    }
    .svc-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform .2s, box-shadow .2s;
        animation: fadeInUp .4s ease both;
    }
    .svc-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }

    .svc-img-wrap { position: relative; height: 160px; overflow: hidden; }
    .svc-img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform .4s;
    }
    .svc-card:hover .svc-img { transform: scale(1.06); }
    .svc-cat-badge {
        position: absolute;
        top: 12px; left: 12px;
        background: rgba(0,0,0,.55);
        backdrop-filter: blur(4px);
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .svc-status-badge {
        position: absolute;
        top: 12px; right: 12px;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 8px;
    }
    .sb-active { background: #d1fae5; color: #065f46; }
    .sb-inactive { background: #fee2e2; color: #991b1b; }

    .svc-body { padding: 18px; }
    .svc-name {
        font-family: 'Outfit', sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .svc-desc {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 14px;
    }
    .svc-price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }
    .svc-price {
        font-family: 'Outfit', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: var(--text);
    }
    .svc-price span { font-size: 13px; font-weight: 400; color: var(--text-muted); }
    .svc-actions {
        display: flex;
        gap: 8px;
        border-top: 1px solid var(--border);
        padding-top: 14px;
    }
    .svc-btn {
        flex: 1;
        padding: 9px 12px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all .2s;
        border: 1.5px solid transparent;
        cursor: pointer;
        font-family: inherit;
    }
    .svc-btn-edit {
        background: var(--accent-bg);
        color: var(--accent-txt);
        border-color: rgba(30,204,96,.25);
    }
    .svc-btn-edit:hover { background: var(--accent); color: #fff; }
    .svc-btn-del {
        background: var(--red-bg);
        color: var(--red-txt);
        border-color: rgba(220,38,38,.2);
    }
    .svc-btn-del:hover { background: var(--red); color: #fff; }

    /* ── Empty State ─────────────────────────────────────── */
    .svc-empty {
        text-align: center;
        padding: 80px 32px;
        background: var(--surface);
        border: 2px dashed var(--border);
        border-radius: 20px;
    }
    .svc-empty-icon {
        width: 88px; height: 88px;
        background: var(--accent-bg);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px;
        font-size: 44px;
        color: var(--accent);
    }
    .svc-empty h2 { font-family: 'Outfit',sans-serif; font-size: 24px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .svc-empty p { color: var(--text-muted); margin-bottom: 28px; font-size: 14px; }

    @@media (max-width: 580px) { .svc-grid { grid-template-columns: 1fr; } }
</style>

<div class="svc-wrap">

    <!-- Page Header -->
    <div class="page-hdr">
        <div class="page-hdr-left">
            <h1>My Services</h1>
            <p>Manage the services you offer to customers</p>
        </div>
        <a asp-action="AddService" class="btn-add-svc">
            <i class="ti ti-plus"></i> Add New Service
        </a>
    </div>

    <!-- Stats -->
    <div class="svc-stats">
        <div class="svc-stat-pill">
            <div class="svc-stat-icon" style="color:var(--accent);"><i class="ti ti-tools"></i></div>
            <div>
                <div class="svc-stat-num">@total</div>
                <div class="svc-stat-lbl">Total Services</div>
            </div>
        </div>
        <div class="svc-stat-pill">
            <div class="svc-stat-icon" style="color:#10b981;"><i class="ti ti-circle-check"></i></div>
            <div>
                <div class="svc-stat-num">@active</div>
                <div class="svc-stat-lbl">Active</div>
            </div>
        </div>
        <div class="svc-stat-pill">
            <div class="svc-stat-icon" style="color:#ef4444;"><i class="ti ti-player-pause"></i></div>
            <div>
                <div class="svc-stat-num">@(total - active)</div>
                <div class="svc-stat-lbl">Inactive</div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="svc-grid">
            @{ int sIdx = 0; }
            @foreach (var s in Model)
            {
                sIdx++;
                <div class="svc-card" style="animation-delay:@(sIdx * 0.06)s;">
                    <div class="svc-img-wrap">
                        <img src="/Images/@(s.ImageUrl ?? "default-svc.png")" class="svc-img"
                             onerror="this.src='/Images/default-svc.png';" alt="@s.Name" />
                        @if (!string.IsNullOrEmpty(s.Category?.Name))
                        {
                            <div class="svc-cat-badge"><i class="ti ti-tag"></i> @s.Category.Name</div>
                        }
                        <span class="svc-status-badge @(s.Status?.ToLower() == "active" ? "sb-active" : "sb-inactive")">
                            @(s.Status ?? "Inactive")
                        </span>
                    </div>
                    <div class="svc-body">
                        <div class="svc-name">@s.Name</div>
                        <div class="svc-desc">@(string.IsNullOrEmpty(s.Description) ? "No description provided." : s.Description)</div>
                        <div class="svc-price-row">
                            <div class="svc-price">₹@s.Price <span>/ visit</span></div>
                        </div>
                        <div class="svc-actions">
                            <a asp-action="EditService" asp-route-id="@s.Id" class="svc-btn svc-btn-edit">
                                <i class="ti ti-edit"></i> Edit
                            </a>
                            <a asp-action="DeleteService" asp-route-id="@s.Id" class="svc-btn svc-btn-del"
                               onclick="return confirm('Delete \'@s.Name\'? This cannot be undone.');">
                                <i class="ti ti-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="svc-empty">
            <div class="svc-empty-icon"><i class="ti ti-tools"></i></div>
            <h2>No Services Yet</h2>
            <p>Start by adding your first service to attract customers.</p>
            <a asp-action="AddService" class="btn-add-svc">
                <i class="ti ti-plus"></i> Add First Service
            </a>
        </div>
    }

</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("page-title").innerText = "My Services";
        document.getElementById("page-crumb").innerText = "Services";
    });
</script>
